// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Staff {
  id           String        @id @default(cuid())
  fullName     String
  username     String        @unique
  passwordHash String
  roleId       String
  role         Role          @relation(fields: [roleId], references: [id])
  records      ClinicalRecord[]
  prescriptions PrescriptionRecord[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Role {
  id      String  @id @default(cuid())
  name    String  @unique // "staff", "vet_admin", "owner"
  staffs  Staff[]
}

model PetOwner {
  id            String    @id @default(cuid())
  firstName     String
  lastName      String
  contactNumber String?
  email         String?
  address       String?
  pets          Pet[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Pet {
  id          String    @id @default(cuid())
  ownerId     String
  owner       PetOwner  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name        String
  species     String?
  breed       String?
  gender      String?
  dateOfBirth String?
  forms       Form[]
  records     ClinicalRecord[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model PurposeOfVisit {
  id      String           @id @default(cuid())
  name    String           @unique // "grooming", "check_up", "surgery", "lab_test"
  records ClinicalRecord[]
}

model ClinicalRecord {
  id            String         @id @default(cuid())
  petId         String
  pet           Pet            @relation(fields: [petId], references: [id], onDelete: Cascade)
  visitDate     DateTime
  purposeId     String
  purpose       PurposeOfVisit @relation(fields: [purposeId], references: [id])
  status        String         @default("Pending") // Added for dashboard workflow
  notes         String?
  diagnosis     String?
  treatment     String?
  createdById   String
  createdBy     Staff          @relation(fields: [createdById], references: [id])
  prescriptions PrescriptionRecord[]
  reminders     SmsReminder[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model PrescriptionRecord {
  id               String         @id @default(cuid())
  recordId         String
  record           ClinicalRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  createdById      String
  createdBy        Staff          @relation(fields: [createdById], references: [id])
  prescriptionDate DateTime       @default(now())
  medicationName   String
  dosage           String
  duration         String?        // ERD says "time" but duration usually varchar/string
  instructions     String?
  exportedPdfLink  String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model ReminderType {
  id        String        @id @default(cuid())
  name      String        @unique // "follow_up", "vaccination_due", "lab_test_sched", "grooming"
  reminders SmsReminder[]
}

model SmsStatus {
  id        String        @id @default(cuid())
  name      String        @unique // "sent", "pending", "failed"
  reminders SmsReminder[]
}

model SmsReminder {
  id             String         @id @default(cuid())
  recordId       String
  record         ClinicalRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  reminderTypeId String
  reminderType   ReminderType   @relation(fields: [reminderTypeId], references: [id])
  reminderDate   DateTime
  smsStatusId    String
  smsStatus      SmsStatus      @relation(fields: [smsStatusId], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model FormType {
  id    String @id @default(cuid())
  name  String @unique // "waiver_lab_test", "sedation_grooming", "surgery_consent"
  forms Form[]
}

model Form {
  id           String   @id @default(cuid())
  petId        String
  pet          Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  formTypeId   String
  formType     FormType @relation(fields: [formTypeId], references: [id])
  formDate     DateTime @default(now())
  formFileLink String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ItemType {
  id        String      @id @default(cuid())
  name      String      @unique // "medication", "grooming", "lab_supply"
  inventory Inventory[]
}

model Inventory {
  id         String   @id @default(cuid())
  itemName   String
  itemTypeId String
  itemType   ItemType @relation(fields: [itemTypeId], references: [id])
  stock      Int      @default(0) // Added stock as it's implied for inventory
  unit       String?  @default("pcs")
  expiryDate DateTime?
  status     String?  @default("Ok")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
